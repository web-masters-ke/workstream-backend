NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://kaizen:kaizen@localhost:5432/kaizen?schema=public

# JWT
JWT_SECRET=replace-me

# Firebase Cloud Messaging (optional — if unset, FCM sends are logged only)
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Media storage
MEDIA_DRIVER=local          # local | s3
MEDIA_LOCAL_DIR=./uploads
MEDIA_PUBLIC_BASE_URL=http://localhost:3000/media

# S3 (when MEDIA_DRIVER=s3)
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PREFIX=kaizen/
